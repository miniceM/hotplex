# ==============================================================================
# HotPlex Environment Configuration Template
# ==============================================================================
# 📋 Usage:
# 1. Copy this file to '.env' (for host mode) or '.env-*' (for Docker):
#    cp .env.example .env
# 2. Update the variables below with your actual credentials.
# 3. For security, NEVER commit your actual '.env' files to version control.
#
# Path Conventions:
# - HotPlex uses ~ (tilde) for home directory expansion.
# - ${HOTPLEX_BOT_ID} is expanded at runtime for instance isolation.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Identity & Context (REQUIRED)
# ------------------------------------------------------------------------------
# Unique identifier for this bot instance. Mandatory for session and storage isolation.
# For Slack, use your Bot User ID (e.g., UXXXXXXXXXX).
# This ID is used for: session isolation, storage paths, bot-specific configurations.
HOTPLEX_BOT_ID=UXXXXXXXXXX

# ------------------------------------------------------------------------------
# 2. Core Server Settings
# ------------------------------------------------------------------------------
# The port the daemon will listen on.
HOTPLEX_PORT=8080

# Logging level: debug, info, warn, error (Default: info)
HOTPLEX_LOG_LEVEL=info

# Logging format: text (readable), json (structured)
HOTPLEX_LOG_FORMAT=text

# API Security Key for administrative operations (Web UI, etc.)
# Highly recommended for production. Generate one with: openssl rand -hex 32
HOTPLEX_API_KEY=your-secure-api-key-here

# Multiple API Keys (comma-separated, optional)
# HOTPLEX_API_KEYS=key1,key2

# ------------------------------------------------------------------------------
# 3. Engine & Provider (Core AI)
# ------------------------------------------------------------------------------
# Execution timeouts for AI tasks
HOTPLEX_EXECUTION_TIMEOUT=30m
HOTPLEX_IDLE_TIMEOUT=1h

# Primary engine type for AI task execution (Default: claude-code)
# Options: claude-code, opencode, pi
HOTPLEX_PROVIDER_TYPE=claude-code

# Provider model (e.g., sonnet, opus, haiku)
HOTPLEX_PROVIDER_MODEL=sonnet

# Optional: Absolute path to the specific provider binary
# HOTPLEX_PROVIDER_BINARY=/usr/local/bin/claude

# OpenCode Compatibility layer (Default: true)
# Allows usage with OpenCode-compatible tools and IDE extensions.
HOTPLEX_OPENCODE_COMPAT_ENABLED=true

# ------------------------------------------------------------------------------
# 4. Message Store (Persistence Layer)
# ------------------------------------------------------------------------------
# Enable or disable persistent chat history
HOTPLEX_MESSAGE_STORE_ENABLED=true

# Storage backend type: sqlite, postgres, memory (Default: sqlite)
HOTPLEX_MESSAGE_STORE_TYPE=sqlite

# SQLite-specific configuration
# Note: ~ expansion is supported.
HOTPLEX_MESSAGE_STORE_SQLITE_PATH=~/.hotplex/instances/${HOTPLEX_BOT_ID}/storage/chatapp_messages.db
HOTPLEX_MESSAGE_STORE_SQLITE_MAX_SIZE_MB=1024

# Real-time streaming storage (captures partial responses)
HOTPLEX_MESSAGE_STORE_STREAMING_ENABLED=true
HOTPLEX_MESSAGE_STORE_STREAMING_TIMEOUT=5m

# ------------------------------------------------------------------------------
# 5. Native Brain (Optional System 1)
# ------------------------------------------------------------------------------
# Fast, low-latency AI for classification and simple decision making.
# HOTPLEX_BRAIN_API_KEY=your-api-key
# HOTPLEX_BRAIN_PROVIDER=openai
# HOTPLEX_BRAIN_MODEL=gpt-4o-mini

# ------------------------------------------------------------------------------
# 6. GitHub Integration
# ------------------------------------------------------------------------------
# Personal Access Token (PAT) for Git operations, PR creation, and repository management.
GITHUB_TOKEN=ghp_your-token-here

# ------------------------------------------------------------------------------
# 7. ChatApps: Platform Bot Configuration
# ------------------------------------------------------------------------------
# Enable ChatApps adapters (Slack, Feishu, etc.)
HOTPLEX_CHATAPPS_ENABLED=true

# ------------------------------------------------------------------------------
# 7.1 Slack Bot Configuration
# ------------------------------------------------------------------------------
# Required: Slack Bot Credentials (from https://api.slack.com/apps)
HOTPLEX_SLACK_BOT_USER_ID=${HOTPLEX_BOT_ID}
HOTPLEX_SLACK_BOT_TOKEN=xoxb-your-bot-token
HOTPLEX_SLACK_APP_TOKEN=xapp-your-app-token
# Optional: Signing secret for webhook verification
# HOTPLEX_SLACK_SIGNING_SECRET=your-signing-secret

# Access Control: Your Slack User ID (the human user)
HOTPLEX_SLACK_PRIMARY_OWNER=UXXXXXXXXXX

# Execution Environment: Working directory for CLI operations
HOTPLEX_PROJECTS_DIR=~/.hotplex/instances/${HOTPLEX_BOT_ID}/projects

# ------------------------------------------------------------------------------
# 7.2 Feishu (飞书) Bot Configuration (Optional)
# ------------------------------------------------------------------------------
# Uncomment to enable Feishu bot
# HOTPLEX_FEISHU_APP_ID=cli_xxx
# HOTPLEX_FEISHU_APP_SECRET=xxx
# HOTPLEX_FEISHU_VERIFICATION_TOKEN=xxx
# HOTPLEX_FEISHU_ENCRYPT_KEY=xxx

# ------------------------------------------------------------------------------
# 7.3 DingTalk Bot Configuration (Optional)
# ------------------------------------------------------------------------------
# Uncomment to enable DingTalk bot
# HOTPLEX_DINGTALK_APP_KEY=xxx
# HOTPLEX_DINGTALK_APP_SECRET=xxx

# ------------------------------------------------------------------------------
# 8. Security & CORS
# ------------------------------------------------------------------------------
# List of origins allowed to access the API (comma-separated)
# HOTPLEX_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ------------------------------------------------------------------------------
# 9. Git Identity
# ------------------------------------------------------------------------------
# Global Git configuration used for commits made by the daemon/container.
GIT_USER_NAME="HotPlex Core"
GIT_USER_EMAIL=core@hotplex.dev

# ------------------------------------------------------------------------------
# 10. Orchestration (Docker/Compose Options)
# ------------------------------------------------------------------------------
# These variables are primarily used by Docker Compose scripts.
# COMPOSE_FILE=docker/matrix/docker-compose.yml
# HOTPLEX_IMAGE=hotplex:latest
# HOST_UID=1000
# HOTPLEX_HOST_CONFIGS_DIR=~/.hotplex/configs

# ==============================================================================
# Fine-grained platform behavior can be configured in:
# - ~/.hotplex/configs/chatapps/slack.yaml
# - ~/.hotplex/configs/chatapps/feishu.yaml
#
# These YAML files support advanced configuration like:
# - Bot behavior (mode, policies)
# - AI provider settings
# - Security rules
# - Message storage options
# ==============================================================================
