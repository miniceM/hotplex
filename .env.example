# ==============================================================================
# 🚀 HotPlex Environment Configuration Template
# ==============================================================================
# Instructions:
# 1. Copy this file to '.env': cp .env.example .env
# 2. Update variables below with your actual credentials.
# 3. For security, never commit your '.env' file to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. 🌐 CORE SERVER SETTINGS
# ------------------------------------------------------------------------------

# Port for the HotPlex proxy server to listen on
HOTPLEX_PORT=8080

# API Security & Authentication (REQUIRED for Production)
# This token controls access to the HotPlex control plane (WebSocket & HTTP APIs).
#
# Usage:
#   - Header:   X-API-Key: <your-token>
#   - Query:    ?api_key=<your-token>
#
# How to Generate:
#   Run 'openssl rand -hex 32' in your terminal to generate a strong random token.
#
# Support for multiple keys (comma-separated):
#   HOTPLEX_API_KEYS=key1,key2
# Single key:
HOTPLEX_API_KEY=generate-a-strong-token-here

# ------------------------------------------------------------------------------
# 2. 🤖 AI PROVIDER CONFIGURATION
# ------------------------------------------------------------------------------

# Backend Provider Type: claude-code (Anthropic Claude Code) or opencode (OpenCode CLI)
HOTPLEX_PROVIDER_TYPE=claude-code

# CLI Binary Path (Optional)
# If empty, HotPlex looks in system $PATH for 'claude' or 'opencode'
HOTPLEX_PROVIDER_BINARY=

# Model Alias (Optional)
# e.g., 'sonnet', 'opus' or specific version string.
HOTPLEX_PROVIDER_MODEL=sonnet

# OpenCode Compatibility Layer (Default: true)
# Enables legacy /session and /global routes for seamless migration.
HOTPLEX_OPENCODE_COMPAT_ENABLED=true

# ------------------------------------------------------------------------------
# 2.1 🧠 NATIVE BRAIN (PLATFORM INTELLIGENCE)
# ------------------------------------------------------------------------------
# The Native Brain handles orchestration like intent routing, safety, and 
# long-term memory compression. It defaults to 'openai' which handles any 
# OpenAI-compatible API (DeepSeek, Groq, etc).
# The brain module is implicitly enabled when HOTPLEX_BRAIN_API_KEY is provided.

# Provider Type: openai (Default)
HOTPLEX_BRAIN_PROVIDER=openai

# Model for fast, internal reasoning (Default: gpt-4o-mini)
HOTPLEX_BRAIN_MODEL=gpt-4o-mini

# API Key for the context brain (Required for brain features)
HOTPLEX_BRAIN_API_KEY=

# Custom API Endpoint (Optional, for DeepSeek/vLLM/Local-LLM)
# e.g., https://api.deepseek.com/v1
HOTPLEX_BRAIN_ENDPOINT=

# ------------------------------------------------------------------------------
# 3. ⚡ ENGINE PERFORMANCE & SAFETY
# ------------------------------------------------------------------------------

# Execution Timeout (Default: 30m)
# Maximum time an AI process can run per turn before being killed.
HOTPLEX_EXECUTION_TIMEOUT=30m

# Session Idle Timeout (Default: 30m)
# Automatically shuts down backend CLI processes after inactivity.
HOTPLEX_IDLE_TIMEOUT=30m

# Log Level: DEBUG, INFO, WARN, ERROR
HOTPLEX_LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# 4. 💬 CHATAPPS (BOT ADAPTERS)
# ------------------------------------------------------------------------------

# Enable/Disable the ChatBot layer globally
HOTPLEX_CHATAPPS_ENABLED=false
# --- Slack App ---
# Detailed setup: see chatapps/configs/slack.yaml
#
# Get tokens from: https://api.slack.com/apps
#   1. Create App -> From scratch
#   2. Socket Mode: Enable Socket Mode in App Home -> Generate App-Level Token
#   3. HTTP Mode: Event Subscriptions -> Request URL -> Install to Workspace
#
# Required tokens:
#   - HOTPLEX_SLACK_BOT_TOKEN: Bot User OAuth Token (xoxb-*) from OAuth & Permissions
#   - HOTPLEX_SLACK_APP_TOKEN: App-Level Token (xapp-*) for Socket Mode
#   - HOTPLEX_SLACK_SIGNING_SECRET: Signing Secret from Basic Information
HOTPLEX_SLACK_MODE=socket
HOTPLEX_SLACK_BOT_TOKEN=
HOTPLEX_SLACK_APP_TOKEN=
HOTPLEX_SLACK_SIGNING_SECRET=

# --- Telegram ---
HOTPLEX_TELEGRAM_BOT_TOKEN=
HOTPLEX_TELEGRAM_WEBHOOK_URL=
HOTPLEX_TELEGRAM_SECRET_TOKEN=

# --- Discord ---
HOTPLEX_DISCORD_BOT_TOKEN=
HOTPLEX_DISCORD_PUBLIC_KEY=

# --- DingTalk ---
HOTPLEX_DINGTALK_APP_ID=
HOTPLEX_DINGTALK_APP_SECRET=
HOTPLEX_DINGTALK_CALLBACK_TOKEN=
HOTPLEX_DINGTALK_CALLBACK_KEY=

# --- WhatsApp (Meta) ---
HOTPLEX_WHATSAPP_PHONE_NUMBER_ID=
HOTPLEX_WHATSAPP_ACCESS_TOKEN=
HOTPLEX_WHATSAPP_VERIFY_TOKEN=

# ------------------------------------------------------------------------------
# 5. 🛠 ADVANCED & OBSERVABILITY
# ------------------------------------------------------------------------------

# CORS: Comma-separated allowed origins for browser-based clients.
HOTPLEX_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# DingTalk Security Alerts (For system blocks and critical errors)
HOTPLEX_DINGTALK_ENABLED=false
HOTPLEX_DINGTALK_WEBHOOK_URL=
HOTPLEX_DINGTALK_SECRET=
HOTPLEX_DINGTALK_FILTER_EVENTS=danger.blocked,session.error

# ------------------------------------------------------------------------------
# 6. ✨ SYSTEM DEFAULTS
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# 7. 📁 CONFIGURATION DIRECTORY
# ------------------------------------------------------------------------------
# Configuration directory search priority:
# 1. HOTPLEX_CHATAPPS_CONFIG_DIR (highest priority, backward compatible)
# 2. ~/.hotplex/configs (user config directory)
# 3. ./chatapps/configs (default, bundled with code)

# User configuration root directory
# Default: ~/.hotplex
# HOTPLEX_CONFIG_DIR=/path/to/hotplex

# ChatApps configuration directory
# Default: {HOTPLEX_CONFIG_DIR}/configs or ./chatapps/configs
# HOTPLEX_CHATAPPS_CONFIG_DIR=/path/to/configs

# ------------------------------------------------------------------------------
# 8. 🔐 GITHUB TOKEN (For container bot)
# ------------------------------------------------------------------------------
# Allows container to use a different GitHub account than the host.
# Generate from: https://github.com/settings/tokens
# Required scopes: repo, read:org
GITHUB_TOKEN=
